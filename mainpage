  renderNplBars();
  renderCompareTable();
}

function fmt(val, prefix='$', suffix='M', dec=0) {
  if (val === null || val === undefined) return '—';
  return prefix + val.toFixed(dec) + suffix;
}
function fmtPct(val, dec=1) {
  if (val === null || val === undefined) return '—';
  return val.toFixed(dec) + '%';
}

function barColor(b) {
  return b.type === 'pub' ? 'var(--pub)' : 'var(--priv)';
}

function renderAssetBars() {
  const banks = filteredBanks().slice().sort((a,b)=>b.assets-a.assets);
  const max = banks[0]?.assets || 1;
  const el = document.getElementById('assetBars');
  if (!el) return;
  el.innerHTML = banks.map(b => `
    <div class="bar-r">
      <div class="bar-r-name">${b.short}</div>
      <div class="bar-r-track">
        <div class="bar-r-fill" style="width:${(b.assets/max*100).toFixed(1)}%;background:${barColor(b)}"></div>
      </div>
      <div class="bar-r-val">${fmtPct(b.assetShare)}</div>
    </div>
  `).join('');
}

function renderLoanBars() {
  const banks = filteredBanks().filter(b=>b.loans).slice().sort((a,b)=>b.loans-a.loans);
  const max = banks[0]?.loans || 1;
  const el = document.getElementById('loanBars');
  if (!el) return;
  el.innerHTML = banks.map(b => `
    <div class="bar-r">
      <div class="bar-r-name">${b.short}</div>
      <div class="bar-r-track">
        <div class="bar-r-fill" style="width:${(b.loans/max*100).toFixed(1)}%;background:${barColor(b)}"></div>
      </div>
      <div class="bar-r-val">${fmt(b.loans)}</div>
    </div>
  `).join('');
}

function renderNplBars() {
  const banks = filteredBanks().filter(b=>b.npl !== null).slice().sort((a,b)=>a.npl-b.npl);
  const el = document.getElementById('nplBars');
  if (!el) return;
  el.innerHTML = banks.map(b => {
    const pct = (b.npl/2.5*100).toFixed(1);
    const col = b.npl < 0.5 ? 'var(--accent)' : b.npl < 1.5 ? 'var(--gold)' : 'var(--red)';
    return `
    <div class="bar-r">
      <div class="bar-r-name">${b.short}</div>
      <div class="bar-r-track">
        <div class="bar-r-fill" style="width:${pct}%;background:${col}"></div>
      </div>
      <div class="bar-r-val" style="color:${col}">${fmtPct(b.npl,2)}</div>
    </div>`;
  }).join('');
}

function sortTable(key) {
  if (sortKey === key) sortAsc = !sortAsc;
  else { sortKey = key; sortAsc = key === 'rank'; }
  document.querySelectorAll('.data-tbl th').forEach(th => th.classList.remove('sorted'));
  renderCompareTable();
}

function renderCompareTable() {
  const banks = filteredBanks().slice();
  banks.sort((a, b) => {
    let av = a[sortKey], bv = b[sortKey];
    if (av === null) av = sortAsc ? Infinity : -Infinity;
    if (bv === null) bv = sortAsc ? Infinity : -Infinity;
    return sortAsc ? av - bv : bv - av;
  });
  const maxAssets = Math.max(...banks.map(b=>b.assets));
  const maxLoans = Math.max(...banks.map(b=>b.loans||0));
  const tbody = document.getElementById('compareBody');
  if (!tbody) return;
  tbody.innerHTML = banks.map((b,i) => {
    const typeBadge = b.type === 'pub'
      ? `<span class="bank-type-badge type-pub">Public</span>`
      : `<span class="bank-type-badge type-priv">Private</span>`;
    const assetBar = `<div class="inline-bar-wrap">
      <div class="inline-bar-track"><div class="inline-bar-fill" style="width:${(b.assets/maxAssets*100).toFixed(0)}%;background:${barColor(b)}"></div></div>
      <span class="mono-val">${fmt(b.assets)}</span>
    </div>`;
    const loanBar = b.loans ? `<div class="inline-bar-wrap">
      <div class="inline-bar-track"><div class="inline-bar-fill" style="width:${(b.loans/maxLoans*100).toFixed(0)}%;background:${barColor(b)}"></div></div>
      <span class="mono-val">${fmt(b.loans)}</span>
    </div>` : '<span class="mono-val neu">—</span>';
    const nplColor = b.npl === null ? '' : b.npl < 0.5 ? 'color:var(--accent)' : b.npl < 1.5 ? 'color:var(--gold)' : 'color:var(--red)';
    return `<tr class="${i===0?'highlighted':''}">
      <td><span class="rank-num">${b.rank.toString().padStart(2,'0')}</span></td>
      <td style="font-weight:500">${b.name}</td>
      <td>${typeBadge}</td>
      <td>${assetBar}</td>
      <td class="mono-val">${fmtPct(b.assetShare)}</td>
      <td>${loanBar}</td>
      <td class="mono-val">${fmtPct(b.loanShare)}</td>
      <td class="mono-val" style="${b.capital && b.capital<9?'color:var(--red)':b.capital?'color:var(--accent)':''}">${fmtPct(b.capital)}</td>
      <td class="mono-val">${fmtPct(b.roe)}</td>
      <td class="mono-val">${fmtPct(b.roa)}</td>
      <td class="mono-val" style="${nplColor}">${fmtPct(b.npl,2)}</td>
    </tr>`;
  }).join('');
}

// ═══ BANK PROFILE ═══
function onBankChange(id) {
  if (!id) return;
  // switch to bank profile view
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('view-bank').classList.add('active');
  document.querySelectorAll('.nav-tab')[2].classList.add('active');
  renderBankProfile(id);
}

function renderBankProfile(id) {
  const b = BANKS.find(x=>x.id===id);
  if (!b) return;
  const desc = BANK_DESC[id] || 'No additional description available.';
  const typeBadge = b.type==='pub'
    ? `<span class="bank-type-badge type-pub">State-owned</span>`
    : `<span class="bank-type-badge type-priv">Private</span>`;
  
  // peers for comparison
  const peers = BANKS.filter(x=>x.type===b.type && x.id!==id).slice(0,3);

  const el = document.getElementById('bankProfile');
  el.innerHTML = `
    <div class="bank-detail mb24">
      <div class="bank-id-card">
        <div class="bank-name-big">${b.name}</div>
        ${typeBadge}
        <div class="stat-row"><div class="stat-name">System rank</div><div class="stat-val">#${b.rank} of 30</div></div>
        <div class="stat-row"><div class="stat-name">Total assets (USD)</div><div class="stat-val" style="color:var(--accent)">$${b.assets.toLocaleString()}M</div></div>
        <div class="stat-row"><div class="stat-name">Asset market share</div><div class="stat-val">${fmtPct(b.assetShare)}</div></div>
        <div class="stat-row"><div class="stat-name">Loan portfolio</div><div class="stat-val">$${b.loans}M</div></div>
        <div class="stat-row"><div class="stat-name">Loan market share</div><div class="stat-val">${fmtPct(b.loanShare)}</div></div>
        <div class="stat-row"><div class="stat-name">Capital adequacy ratio</div><div class="stat-val" style="${b.capital?'color:var(--accent)':''}">${fmtPct(b.capital)}</div></div>
        <div class="stat-row"><div class="stat-name">ROE</div><div class="stat-val">${fmtPct(b.roe)}</div></div>
        <div class="stat-row"><div class="stat-name">ROA</div><div class="stat-val">${fmtPct(b.roa)}</div></div>
        <div class="stat-row" style="border:none"><div class="stat-name">NPL ratio</div>
          <div class="stat-val" style="${b.npl===null?'':b.npl<0.5?'color:var(--accent)':b.npl<1.5?'color:var(--gold)':'color:var(--red)'}">${fmtPct(b.npl,2)}</div></div>
      </div>

      <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="card" style="flex:0 0 auto">
          <div class="card-title">About this institution</div>
          <p style="font-size:13px;color:var(--muted);line-height:1.7">${desc}</p>
          ${b.found ? `<div style="margin-top:10px;font-family:var(--mono);font-size:10px;color:var(--dim)">Est. ${b.found}</div>` : ''}
        </div>

        <div class="bank-charts">
          <!-- position vs system -->
          <div class="card">
            <div class="card-title">Position vs System — Assets</div>
            <svg width="100%" height="160" viewBox="0 0 260 160" preserveAspectRatio="xMidYMid meet">
              ${renderMiniRadar(b)}
            </svg>
          </div>
          <!-- peer comparison -->
          <div class="card">
            <div class="card-title">Peer Comparison — ${b.type==='pub'?'Public':'Private'} Banks</div>
            ${renderPeerBars(b, peers)}
          </div>
        </div>
      </div>
    </div>

    <div class="g4 mb24">
      <div class="card">
        <div class="card-title">Asset Scale</div>
        <div style="text-align:center;padding:16px 0">
          <div style="font-family:var(--mono);font-size:28px;font-weight:700;color:var(--accent)">$${b.assets.toLocaleString()}M</div>
          <div style="font-size:11px;color:var(--muted);margin-top:4px">${fmtPct(b.assetShare)} of system</div>
          <div style="font-size:10px;color:var(--dim);margin-top:8px;font-family:var(--mono)">System total: $11,133M</div>
        </div>
      </div>
      <div class="card">
        <div class="card-title">Credit Portfolio</div>
        <div style="text-align:center;padding:16px 0">
          <div style="font-family:var(--mono);font-size:28px;font-weight:700;color:var(--blue)">$${b.loans}M</div>
          <div style="font-size:11px;color:var(--muted);margin-top:4px">${fmtPct(b.loanShare)} of total credit</div>
          <div style="font-size:10px;color:var(--dim);margin-top:8px;font-family:var(--mono)">Intermediation: ~${((b.loans/(b.assets*0.52))*100).toFixed(0)}% est.</div>
        </div>
      </div>
      <div class="card">
        <div class="card-title">Capital Strength</div>
        <div style="text-align:center;padding:16px 0">
          <div style="font-family:var(--mono);font-size:28px;font-weight:700;color:${b.capital?b.capital>20?'var(--accent)':'var(--gold)':'var(--muted)'}">${fmtPct(b.capital)}</div>
          <div style="font-size:11px;color:var(--muted);margin-top:4px">Capital adequacy ratio</div>
          <div style="font-size:10px;color:var(--dim);margin-top:8px;font-family:var(--mono)">Min required: 9%</div>
        </div>
      </div>
      <div class="card">
        <div class="card-title">Asset Quality</div>
        <div style="text-align:center;padding:16px 0">
          <div style="font-family:var(--mono);font-size:28px;font-weight:700;color:${b.npl===null?'var(--muted)':b.npl<0.5?'var(--accent)':b.npl<1.5?'var(--gold)':'var(--red)'}">${fmtPct(b.npl,2)}</div>
          <div style="font-size:11px;color:var(--muted);margin-top:4px">NPL ratio</div>
          <div style="font-size:10px;color:var(--dim);margin-top:8px;font-family:var(--mono)">System avg: 2.03%</div>
        </div>
      </div>
    </div>
  `;
}

function renderMiniRadar(b) {
  // Simple horizontal position bar vs system
  const items = [
    { label:'Assets', val:b.assetShare, max:55, color:'var(--accent)' },
    { label:'Loans',  val:b.loanShare,  max:35, color:'var(--blue)' },
    { label:'CAR',    val:b.capital,    max:40, color:'var(--gold)' },
    { label:'NPL',    val:b.npl,        max:3,  color:'var(--red)', invert:true },
  ];
  return items.map((item,i)=>{
    const y = 20 + i*34;
    const pct = item.val===null ? 0 : Math.min(item.val/item.max*180, 180);
    const col = item.val===null ? 'var(--dim)' : item.color;
    return `
      <text x="0" y="${y+5}" font-size="9" fill="var(--muted)">${item.label}</text>
      <rect x="60" y="${y}" width="180" height="10" rx="2" fill="var(--panel)"/>
      <rect x="60" y="${y}" width="${pct}" height="10" rx="2" fill="${col}" opacity="0.8"/>
      <text x="248" y="${y+9}" font-size="8" fill="${item.val===null?'var(--dim)':col}" text-anchor="end">${item.val===null?'—':item.label==='NPL'?item.val.toFixed(2)+'%':item.val.toFixed(1)+'%'}</text>
    `;
  }).join('');
}

function renderPeerBars(b, peers) {
  const all = [b, ...peers];
  const maxA = Math.max(...all.map(x=>x.assets));
  return all.map(x=>`
    <div class="bar-r">
      <div class="bar-r-name" style="${x.id===b.id?'color:var(--accent);font-weight:600':''}">
        ${x.short}${x.id===b.id?' ←':''}
      </div>
      <div class="bar-r-track">
        <div class="bar-r-fill" style="width:${(x.assets/maxA*100).toFixed(1)}%;background:${x.id===b.id?'var(--accent)':barColor(x)};opacity:${x.id===b.id?1:0.5}"></div>
      </div>
      <div class="bar-r-val">${fmt(x.assets)}</div>
    </div>
  `).join('');
}

// ═══ INIT ═══
renderAll();
</script>
