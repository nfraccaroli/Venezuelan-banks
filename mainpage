<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Venezuelan Banking System — Interactive Explorer</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
  --bg:       #0b0f14;
  --panel:    #111720;
  --card:     #16202e;
  --border:   #1e2d3d;
  --border2:  #253444;
  --accent:   #00c896;
  --accent-d: #009e78;
  --gold:     #f5c542;
  --blue:     #3b9eff;
  --red:      #ff5c5c;
  --orange:   #ff8c42;
  --pub:      #3b9eff;
  --priv:     #f5c542;
  --text:     #e4eaf2;
  --muted:    #6b8099;
  --dim:      #334455;
  --mono:     'JetBrains Mono', monospace;
  --sans:     'Inter', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  font-size: 14px;
  min-height: 100vh;
}

/* ═══ TOP NAV ═══ */
.nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(11,15,20,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 28px;
  height: 56px;
}
.nav-brand {
  display: flex; align-items: center; gap: 10px;
  font-weight: 700; font-size: 15px; letter-spacing: -0.3px;
}
.nav-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 8px var(--accent);
  animation: pulse 2s ease infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
.nav-right {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--muted);
}
.nav-tabs {
  display: flex; gap: 2px;
}
.nav-tab {
  padding: 6px 14px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
  color: var(--muted);
  cursor: pointer;
  border: none;
  background: transparent;
  transition: all 0.15s;
}
.nav-tab:hover { color: var(--text); background: var(--panel); }
.nav-tab.active { color: var(--accent); background: rgba(0,200,150,0.1); }

/* ═══ SELECTOR PANEL ═══ */
.selector-panel {
  background: var(--panel);
  border-bottom: 1px solid var(--border);
  padding: 16px 28px;
  display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
}
.selector-label {
  font-size: 11px;
  font-family: var(--mono);
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  white-space: nowrap;
}
.select-wrap {
  position: relative;
}
.select-wrap select {
  appearance: none;
  background: var(--card);
  border: 1px solid var(--border2);
  color: var(--text);
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 500;
  padding: 8px 36px 8px 12px;
  border-radius: 6px;
  cursor: pointer;
  outline: none;
  min-width: 220px;
  transition: border-color 0.15s;
}
.select-wrap select:hover { border-color: var(--accent); }
.select-wrap select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,200,150,0.15); }
.select-wrap::after {
  content: '▾';
  position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
  color: var(--muted); pointer-events: none; font-size: 12px;
}
.filter-pills {
  display: flex; gap: 6px;
}
.pill {
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 500;
  cursor: pointer;
  border: 1px solid var(--border2);
  background: transparent;
  color: var(--muted);
  transition: all 0.15s;
  white-space: nowrap;
}
.pill:hover { border-color: var(--accent); color: var(--text); }
.pill.active-all  { border-color: var(--text); color: var(--text); background: rgba(255,255,255,0.06); }
.pill.active-pub  { border-color: var(--pub); color: var(--pub); background: rgba(59,158,255,0.1); }
.pill.active-priv { border-color: var(--priv); color: var(--priv); background: rgba(245,197,66,0.1); }

.separator { width: 1px; height: 28px; background: var(--border); }

/* ═══ MAIN CONTENT ═══ */
.main { padding: 24px 28px 48px; }

/* ═══ SYSTEM HERO STRIP ═══ */
.hero-strip {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
  margin-bottom: 24px;
}
.hero-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  position: relative;
  overflow: hidden;
}
.hero-card::after {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
}
.hero-card.c-green::after  { background: var(--accent); }
.hero-card.c-blue::after   { background: var(--blue); }
.hero-card.c-gold::after   { background: var(--gold); }
.hero-card.c-orange::after { background: var(--orange); }
.hero-card.c-red::after    { background: var(--red); }

.hero-lbl {
  font-size: 10px;
  font-family: var(--mono);
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.09em;
  margin-bottom: 8px;
}
.hero-val {
  font-size: 26px;
  font-weight: 700;
  font-family: var(--mono);
  letter-spacing: -1px;
  line-height: 1;
}
.hero-val.c-green  { color: var(--accent); }
.hero-val.c-blue   { color: var(--blue); }
.hero-val.c-gold   { color: var(--gold); }
.hero-val.c-orange { color: var(--orange); }
.hero-val.c-red    { color: var(--red); }
.hero-sub { font-size: 11px; color: var(--muted); margin-top: 5px; font-family: var(--mono); }
.hero-delta { font-size: 10px; margin-top: 6px; font-family: var(--mono); }
.up  { color: var(--accent); }
.dn  { color: var(--red); }
.neu { color: var(--muted); }

/* ═══ VIEW SECTIONS ═══ */
.view { display: none; }
.view.active { display: block; }

/* ═══ BANK DETAIL CARD ═══ */
.bank-detail {
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: 20px;
  margin-bottom: 24px;
}
.bank-id-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 24px;
}
.bank-name-big {
  font-size: 20px;
  font-weight: 700;
  letter-spacing: -0.4px;
  line-height: 1.2;
  margin-bottom: 6px;
}
.bank-type-badge {
  display: inline-block;
  font-size: 10px;
  font-family: var(--mono);
  padding: 3px 8px;
  border-radius: 3px;
  margin-bottom: 18px;
}
.type-pub  { background: rgba(59,158,255,0.15); color: var(--pub); border: 1px solid rgba(59,158,255,0.3); }
.type-priv { background: rgba(245,197,66,0.15); color: var(--priv); border: 1px solid rgba(245,197,66,0.3); }

.stat-row {
  display: flex; justify-content: space-between; align-items: baseline;
  padding: 9px 0;
  border-bottom: 1px solid var(--border);
}
.stat-row:last-child { border-bottom: none; }
.stat-name { font-size: 11px; color: var(--muted); }
.stat-val  { font-size: 13px; font-family: var(--mono); font-weight: 500; color: var(--text); }

.bank-charts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* ═══ COMPARE TABLE ═══ */
.tbl-wrap { overflow-x: auto; }
table.data-tbl {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}
.data-tbl th {
  font-family: var(--mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted);
  text-align: left;
  padding: 0 12px 10px 0;
  border-bottom: 1px solid var(--border);
  white-space: nowrap;
  cursor: pointer;
  user-select: none;
}
.data-tbl th:hover { color: var(--text); }
.data-tbl th.sorted { color: var(--accent); }
.data-tbl th:last-child { text-align: right; }
.data-tbl td {
  padding: 10px 12px 10px 0;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}
.data-tbl tr:hover td { background: rgba(255,255,255,0.015); }
.data-tbl tr.highlighted td { background: rgba(0,200,150,0.04); }
.data-tbl td:last-child { text-align: right; }
.mono-val { font-family: var(--mono); font-size: 12px; }
.rank-num { font-family: var(--mono); font-size: 10px; color: var(--dim); margin-right: 6px; }

/* bars inside table */
.inline-bar-wrap { display: flex; align-items: center; gap: 8px; }
.inline-bar-track {
  flex: 1; height: 4px;
  background: var(--border); border-radius: 2px;
  min-width: 60px; max-width: 120px;
}
.inline-bar-fill { height: 100%; border-radius: 2px; transition: width 0.4s ease; }

/* ═══ CARD GENERIC ═══ */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 20px;
}
.card-title {
  font-size: 11px;
  font-family: var(--mono);
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.09em;
  margin-bottom: 16px;
}

/* ═══ SVG CHARTS ═══ */
svg text { font-family: 'JetBrains Mono', monospace; }

/* ═══ BAR ROWS ═══ */
.bar-section { margin-bottom: 10px; }
.bar-r { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.bar-r-name {
  font-size: 11px; color: var(--text);
  width: 160px; flex-shrink: 0;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.bar-r-track {
  flex: 1; height: 14px;
  background: var(--panel); border-radius: 2px; overflow: hidden;
}
.bar-r-fill { height: 100%; border-radius: 2px; transition: width 0.5s cubic-bezier(.4,0,.2,1); }
.bar-r-val {
  font-family: var(--mono); font-size: 10px;
  color: var(--muted); width: 60px; text-align: right; flex-shrink: 0;
}

/* ═══ LEGEND ═══ */
.legend { display: flex; gap: 20px; font-size: 11px; align-items: center; margin-top: 12px; }
.leg-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

/* ═══ GRID LAYOUTS ═══ */
.g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.g3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.g4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16px; }
.mb16 { margin-bottom: 16px; }
.mb24 { margin-bottom: 24px; }

/* ═══ CONTEXT BOX ═══ */
.context {
  background: rgba(0,200,150,0.04);
  border: 1px solid rgba(0,200,150,0.15);
  border-radius: 8px;
  padding: 16px 18px;
  font-size: 12px;
  color: var(--muted);
  line-height: 1.75;
}
.context strong { color: var(--text); }

/* ═══ EMPTY STATE ═══ */
.empty {
  text-align: center;
  padding: 60px 20px;
  color: var(--muted);
  font-size: 14px;
}
.empty-icon { font-size: 32px; margin-bottom: 12px; }

/* ═══ RESPONSIVE ═══ */
@media(max-width:1100px) {
  .hero-strip { grid-template-columns: repeat(3,1fr); }
  .bank-detail { grid-template-columns: 1fr; }
  .bank-charts { grid-template-columns: 1fr; }
  .g3,.g4 { grid-template-columns: 1fr 1fr; }
}
@media(max-width:700px) {
  .hero-strip { grid-template-columns: 1fr 1fr; }
  .g2,.g3,.g4 { grid-template-columns: 1fr; }
  .selector-panel { flex-direction: column; align-items: flex-start; }
}
</style>
</head>
<body>

<!-- ════ NAV ════ -->
<nav class="nav">
  <div class="nav-brand">
    <div class="nav-dot"></div>
    Venezuelan Banking Explorer
  </div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="switchView('overview')">System Overview</button>
    <button class="nav-tab" onclick="switchView('compare')">Compare Banks</button>
    <button class="nav-tab" onclick="switchView('bank')">Bank Profile</button>
    <button class="nav-tab" onclick="switchView('sector')">Sector Analysis</button>
  </div>
  <div class="nav-right">Data: Dec 2024 · SUDEBAN</div>
</nav>

<!-- ════ SELECTOR PANEL ════ -->
<div class="selector-panel">
  <span class="selector-label">Select bank</span>
  <div class="select-wrap">
    <select id="bankSelect" onchange="onBankChange(this.value)">
      <option value="">— choose a bank —</option>
      <optgroup label="🏛 State-owned Banks">
        <option value="bdv">Banco de Venezuela (BDV)</option>
        <option value="tesoro">Banco del Tesoro</option>
        <option value="bdt">Banco Digital de los Trabajadores (BDT)</option>
        <option value="bicentenario">Banco Bicentenario</option>
        <option value="bandes">BANDES (Development Bank)</option>
        <option value="banmujer">Banco de la Mujer (Banmujer)</option>
      </optgroup>
      <optgroup label="🏦 Private Banks">
        <option value="banesco">Banesco Banco Universal</option>
        <option value="bnc">BNC — Banco Nacional de Crédito</option>
        <option value="bbva">BBVA Provincial</option>
        <option value="mercantil">Mercantil Banco</option>
        <option value="bancamiga">Bancamiga Banco Universal</option>
        <option value="banplus">Banplus Banco Universal</option>
        <option value="bancaribe">Bancaribe</option>
        <option value="exterior">Banco Exterior</option>
        <option value="plaza">Banco Plaza</option>
        <option value="sofitasa">Banco Sofitasa</option>
        <option value="fondo_comun">Banco Fondo Común (BFC)</option>
        <option value="venezolano_credito">Banco Venezolano de Crédito</option>
        <option value="100banco">100% Banco</option>
        <option value="activo">Banco Activo</option>
      </optgroup>
    </select>
  </div>

  <div class="separator"></div>
  <span class="selector-label">Filter by</span>
  <div class="filter-pills">
    <button class="pill active-all" onclick="setFilter('all',this)">All banks</button>
    <button class="pill" onclick="setFilter('pub',this)">Public only</button>
    <button class="pill" onclick="setFilter('priv',this)">Private only</button>
  </div>

  <div class="separator"></div>
  <span class="selector-label" style="color:var(--muted); font-size:10px;">30 universal banks · 6 state-owned · ~2,000 branches</span>
</div>

<!-- ════ MAIN ════ -->
<div class="main">

  <!-- SYSTEM KPIs — always visible -->
  <div class="hero-strip mb24" id="heroStrip">
    <div class="hero-card c-green">
      <div class="hero-lbl">Total System Assets</div>
      <div class="hero-val c-green">$11.1B</div>
      <div class="hero-sub">Bs 579,263M · Dec 2024</div>
      <div class="hero-delta up">↑ +75.9% YoY (local) · +21.6% real</div>
    </div>
    <div class="hero-card c-blue">
      <div class="hero-lbl">Total Loan Portfolio</div>
      <div class="hero-val c-blue">$2.42B</div>
      <div class="hero-sub">Bs 125,954M</div>
      <div class="hero-delta up">↑ +139% YoY · +51% in USD</div>
    </div>
    <div class="hero-card c-gold">
      <div class="hero-lbl">Public Deposits</div>
      <div class="hero-val c-gold">$5.83B</div>
      <div class="hero-sub">Bs 274,986M</div>
      <div class="hero-delta up">↑ +97% YoY · +49.9% real</div>
    </div>
    <div class="hero-card c-orange">
      <div class="hero-lbl">Avg Capital Adequacy</div>
      <div class="hero-val c-orange">36.1%</div>
      <div class="hero-sub">SUDEBAN min: 9%</div>
      <div class="hero-delta up">↑ +4.9 pp vs Jun 2024</div>
    </div>
    <div class="hero-card c-red">
      <div class="hero-lbl">System NPL Ratio</div>
      <div class="hero-val c-red">2.03%</div>
      <div class="hero-sub">Coverage: 189%</div>
      <div class="hero-delta up">↓ –0.17 pp YoY (improving)</div>
    </div>
  </div>

  <!-- ══ VIEW: OVERVIEW ══ -->
  <div class="view active" id="view-overview">
    <div class="g2 mb24">

      <!-- Asset market share -->
      <div class="card">
        <div class="card-title">Asset Market Share — All Banks</div>
        <div id="assetBars"></div>
        <div class="legend">
          <div style="display:flex;align-items:center;gap:6px;"><div class="leg-dot" style="background:var(--pub)"></div><span style="color:var(--muted)">Public</span></div>
          <div style="display:flex;align-items:center;gap:6px;"><div class="leg-dot" style="background:var(--priv)"></div><span style="color:var(--muted)">Private</span></div>
        </div>
      </div>

      <!-- Loan portfolio share -->
      <div class="card">
        <div class="card-title">Loan Portfolio Share — Top Banks (Sep 2024)</div>
        <div id="loanBars"></div>
      </div>
    </div>

    <div class="g3 mb24">
      <!-- Profitability -->
      <div class="card">
        <div class="card-title">Profitability — System 2024</div>
        <svg width="100%" height="200" viewBox="0 0 260 200" preserveAspectRatio="xMidYMid meet">
          <!-- ROE bars: 2022~15%, 2023~32%, 2024~29.6% -->
          <text x="10" y="16" font-size="9" fill="var(--muted)">ROE (%)</text>
          <!-- grid -->
          <line x1="10" y1="25" x2="250" y2="25" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="4,3"/>
          <line x1="10" y1="62" x2="250" y2="62" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="4,3"/>
          <line x1="10" y1="100" x2="250" y2="100" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="4,3"/>
          <text x="4" y="28" font-size="8" fill="var(--dim)" text-anchor="end">40</text>
          <text x="4" y="65" font-size="8" fill="var(--dim)" text-anchor="end">25</text>
          <text x="4" y="103" font-size="8" fill="var(--dim)" text-anchor="end">10</text>
          <!-- 2022: ~15% -->
          <rect x="20" y="64" width="50" height="36" rx="3" fill="var(--blue)" opacity="0.4"/>
          <text x="45" y="58" font-size="9" fill="var(--muted)" text-anchor="middle">15%</text>
          <text x="45" y="118" font-size="9" fill="var(--muted)" text-anchor="middle">2022</text>
          <!-- 2023: ~32.3% -->
          <rect x="100" y="25" width="50" height="75" rx="3" fill="var(--accent)" opacity="0.5"/>
          <text x="125" y="19" font-size="9" fill="var(--accent)" text-anchor="middle">32.3%</text>
          <text x="125" y="118" font-size="9" fill="var(--muted)" text-anchor="middle">2023</text>
          <!-- 2024: ~29.6% -->
          <rect x="180" y="33" width="50" height="67" rx="3" fill="var(--accent)"/>
          <text x="205" y="27" font-size="9" fill="var(--accent)" text-anchor="middle">29.6%</text>
          <text x="205" y="118" font-size="9" fill="var(--muted)" text-anchor="middle">2024</text>

          <!-- ROA line -->
          <line x1="10" y1="140" x2="250" y2="140" stroke="var(--border)" stroke-width="1"/>
          <text x="10" y="136" font-size="9" fill="var(--muted)">ROA (%)</text>
          <!-- 2022~6.9% 2023~6.9% 2024~5.65% — dots connected -->
          <polyline points="45,163 125,163 205,167" fill="none" stroke="var(--gold)" stroke-width="2"/>
          <circle cx="45" cy="163" r="3.5" fill="var(--gold)"/>
          <circle cx="125" cy="163" r="3.5" fill="var(--gold)"/>
          <circle cx="205" cy="167" r="3.5" fill="var(--gold)"/>
          <text x="45" y="158" font-size="8" fill="var(--gold)" text-anchor="middle">6.9%</text>
          <text x="125" y="158" font-size="8" fill="var(--gold)" text-anchor="middle">6.9%</text>
          <text x="205" y="162" font-size="8" fill="var(--gold)" text-anchor="middle">5.7%</text>
          <text x="45" y="185" font-size="9" fill="var(--muted)" text-anchor="middle">2022</text>
          <text x="125" y="185" font-size="9" fill="var(--muted)" text-anchor="middle">2023</text>
          <text x="205" y="185" font-size="9" fill="var(--muted)" text-anchor="middle">2024</text>
        </svg>
      </div>

      <!-- Deposit composition -->
      <div class="card">
        <div class="card-title">Deposit Structure — Dec 2024</div>
        <svg width="100%" height="200" viewBox="0 0 260 200" preserveAspectRatio="xMidYMid meet">
          <!-- Donut: current accts 93.4%, savings 4.8%, other 1.8% -->
          <circle cx="90" cy="95" r="62" fill="transparent" stroke="var(--accent)" stroke-width="28"
            stroke-dasharray="368.7 18.3" stroke-dashoffset="46" transform="rotate(-90,90,95)"/>
          <circle cx="90" cy="95" r="62" fill="transparent" stroke="var(--blue)" stroke-width="28"
            stroke-dasharray="18.9 368.1" stroke-dashoffset="-322.7" transform="rotate(-90,90,95)"/>
          <circle cx="90" cy="95" r="62" fill="transparent" stroke="var(--dim)" stroke-width="28"
            stroke-dasharray="7" stroke-dashoffset="-341.6" transform="rotate(-90,90,95)"/>
          <circle cx="90" cy="95" r="47" fill="var(--card)"/>
          <text x="90" y="90" text-anchor="middle" font-size="18" fill="var(--text)" font-weight="700">93.4%</text>
          <text x="90" y="105" text-anchor="middle" font-size="9" fill="var(--muted)">current</text>
          <!-- legend -->
